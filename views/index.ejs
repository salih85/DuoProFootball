<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Duo Pro Football - Online Edition</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/socket.io/socket.io.js"></script>
</head>

<body>

    <div id="game-over-overlay" class="overlay hidden">
        <div class="glass-card">
            <h1 id="winner-text">Game Over</h1>
            <p>What a match!</p>
            <button onclick="location.reload()" class="premium-btn">Play Again</button>
        </div>
    </div>

    <div id="lobby-overlay" class="overlay">
        <div class="glass-card">
            <h1>Duo Pro Football</h1>
            <p>Ready for a match?</p>
            <button id="findMatchBtn" class="premium-btn">Find Match</button>
            <div id="searching-text" class="hidden">
                <div class="loader"></div>
                <p>Searching for opponent...</p>
            </div>
        </div>
    </div>

    <div id="game-container" class="game-container hidden">
        <div class="ui-header">
            <div class="score-card p1-score">
                <span class="label">P1</span>
                <span id="score1">0</span>
            </div>
            <div id="goalText" class="goal-announcement">GOAL!</div>
            <div class="score-card p2-score">
                <span id="score2">0</span>
                <span class="label">P2</span>
            </div>
        </div>

        <div class="canvas-wrapper">
            <canvas id="gameCanvas" width="800" height="500"></canvas>
        </div>

    </div>

    <script src="/js/game.js"></script>
</body>

</html>