<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Duo Pro Football - Online Edition</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/socket.io/socket.io.js"></script>
</head>

<body>

    <div id="game-over-overlay" class="overlay hidden">
        <div class="glass-card">
            <h1 id="winner-text">Game Over</h1>
            <p>What a match!</p>
            <button id="playAgainBtn" class="premium-btn">Play Again</button>
        </div>
    </div>

    <!-- Custom Notifications (Toast) -->
    <div id="notification-container" class="notification-container"></div>

    <!-- Goal Announcement -->
    <div id="goalText" class="goal-announcement">GOAL!</div>

    <!-- Exit Confirmation Modal -->
    <div id="exit-confirm-modal" class="overlay hidden">
        <div class="glass-card modal-content small">
            <h2 class="modal-title">EXIT MATCH?</h2>
            <p class="info-text">Are you sure you want to leave the field?</p>
            <div class="modal-actions">
                <button id="confirmExitBtn" class="premium-btn online">Yes, Exit</button>
                <button id="cancelExitBtn" class="premium-btn secondary">No, Stay</button>
            </div>
        </div>
    </div>

    <div id="lobby-overlay" class="overlay">
        <div class="lobby-content">
            <h1 class="game-title">DUO PRO FOOTBALL</h1>
            <p class="game-subtitle">Elite Multi-Player Experience</p>

            <div class="mode-selection">
                <button id="openOnlineModal" class="premium-btn online">
                    <span class="icon">🌍</span>
                    <span class="text">Online Match</span>
                </button>
                <button id="openComputerModal" class="premium-btn computer">
                    <span class="icon">🤖</span>
                    <span class="text">VS Computer</span>
                </button>

            </div>

            <div id="searching-text" class="hidden">
                <div class="loader"></div>
                <p>Searching for opponent...</p>
                <button id="cancelSearchBtn" class="premium-btn secondary">Cancel Search</button>
            </div>
        </div>
    </div>

    <!-- Computer Settings Modal -->
    <div id="computerModal" class="overlay hidden">
        <div class="glass-card modal-content">
            <h2 class="modal-title">VS COMPUTER</h2>
            <div class="settings-grid">
                <div class="setting-item">
                    <p class="setting-label">Your Jersey Color</p>
                    <div class="color-picker" id="compColorPicker">
                        <div class="swatch active" data-color="#3b82f6" style="background: #3b82f6;"></div>
                        <div class="swatch" data-color="#10b981" style="background: #10b981;"></div>
                        <div class="swatch" data-color="#f59e0b" style="background: #f59e0b;"></div>
                        <div class="swatch" data-color="#ef4444" style="background: #ef4444;"></div>
                        <div class="swatch" data-color="#ffffff" style="background: #ffffff;"></div>
                    </div>
                </div>
                <div class="setting-row">
                    <div class="setting-group" style="width: 100%;">
                        <p class="setting-label">Win Limit</p>
                        <select id="compWinLimit" class="premium-select">
                            <option value="3">3 Goals</option>
                            <option value="5" selected>5 Goals</option>
                            <option value="10">10 Goals</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-actions">
                <button id="startComputerBtn" class="premium-btn">Play Now</button>
                <button class="close-modal premium-btn secondary">Back</button>
            </div>
        </div>
    </div>

    <!-- Online Settings Modal -->
    <div id="onlineModal" class="overlay hidden">
        <div class="glass-card modal-content">
            <h2 class="modal-title">ONLINE MATCH</h2>
            <div class="settings-grid">
                <div class="setting-item">
                    <p class="setting-label">Your Jersey Color</p>
                    <div class="color-picker" id="onlineColorPicker">
                        <div class="swatch active" data-color="#3b82f6" style="background: #3b82f6;"></div>
                        <div class="swatch" data-color="#10b981" style="background: #10b981;"></div>
                        <div class="swatch" data-color="#f59e0b" style="background: #f59e0b;"></div>
                        <div class="swatch" data-color="#ef4444" style="background: #ef4444;"></div>
                        <div class="swatch" data-color="#ffffff" style="background: #ffffff;"></div>
                    </div>
                </div>

                <div class="private-room-section">
                    <div class="tab-buttons">
                        <button class="tab-btn active" data-mode="random">Matchmaking</button>
                        <button class="tab-btn" data-mode="private">Play with Friends</button>
                    </div>

                    <div id="online-random-content" class="tab-content">
                        <p class="info-text">Battle against any player online!</p>
                    </div>

                    <div id="online-private-content" class="tab-content hidden">
                        <div class="room-options">
                            <div class="option-create">
                                <p class="setting-label">Create Room</p>
                                <button id="createRoomBtn" class="premium-btn secondary small">Get Room Code</button>
                                <div id="roomCodeArea" class="room-code-area hidden">
                                    <span id="displayRoomCode">----</span>
                                    <button id="copyCodeBtn" class="icon-btn">📋</button>
                                </div>
                                <div class="setting-group compact">
                                    <p class="setting-label">Win Limit</p>
                                    <select id="onlineWinLimit" class="premium-select">
                                        <option value="3">3 Goals</option>
                                        <option value="5" selected>5 Goals</option>
                                        <option value="10">10 Goals</option>
                                    </select>
                                </div>
                            </div>
                            <div class="divider-v"></div>
                            <div class="option-join">
                                <p class="setting-label">Join Room</p>
                                <input type="text" id="joinRoomInput" placeholder="Enter Code" maxlength="5">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-actions">
                <button id="startOnlineBtn" class="premium-btn online">Ready to Play</button>
                <button class="close-modal premium-btn secondary">Back</button>
            </div>
        </div>
    </div>

    <!-- Countdown Overlay -->
    <div id="countdown-overlay" class="overlay hidden"
        style="z-index: 200; flex-direction: column; background: rgba(0,0,0,0.85);">
        <h1 id="countdown-text"
            style="font-size: 8rem; color: #fbbf24; text-shadow: 0 0 20px rgba(251, 191, 36, 0.5); margin: 0; animation: modalPop 0.5s ease-out;">
            5</h1>
        <p style="color: white; font-size: 1.5rem; letter-spacing: 2px; text-transform: uppercase;">Get Ready!</p>
    </div>

    <div id="game-container" class="game-container hidden">
        <div class="ui-header">
            <div id="p1-card" class="score-card p1-score">
                <span id="p1-label" class="label">P1</span>
                <span id="score1">0</span>
            </div>

            <div class="mid-ui">
                <button id="exitMatchBtn" class="icon-btn exit-btn" title="Exit Match">
                    <span class="dots">•••</span>
                </button>
            </div>

            <div id="p2-card" class="score-card p2-score">
                <span id="score2">0</span>
                <span id="p2-label" class="label">P2</span>
            </div>
        </div>

        <div class="canvas-wrapper">
            <canvas id="gameCanvas" width="800" height="500"></canvas>
        </div>

    </div>

    <script src="/js/game.js"></script>
</body>

</html>